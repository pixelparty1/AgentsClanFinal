# =====================================================
# AgentsClan Backend Environment Variables
# Copy this file to .env and fill in your values
# =====================================================

# Server
PORT=3001
NODE_ENV=development

# Appwrite
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-project-id
APPWRITE_API_KEY=your-api-key
APPWRITE_DATABASE_ID=agentsclan_db

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# Blockchain
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology
NFT_CONTRACT_ADDRESS=0xDeployedContractAddress
RELAYER_PRIVATE_KEY=0xYourRelayerPrivateKey
OWNER_WALLET_ADDRESS=0xYourOwnerWallet

# CORS
FRONTEND_URL=http://localhost:3000
